<Window x:Class="Nha_Hang_Huit.Views.ShiftReportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Báo Cáo Đóng Ca"
        WindowStartupLocation="CenterScreen"
        Width="600" Height="500" WindowStyle="ToolWindow" ResizeMode="NoResize"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#00695C" CornerRadius="5,5,0,0" Padding="10">
            <StackPanel>
                <TextBlock Text="{Binding MaCaText}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding GioBatDauText}" Foreground="#B2DFDB" FontSize="13"/>
                <TextBlock Text="{Binding GioKetThucText}" Foreground="#B2DFDB" FontSize="13"/>
                <TextBlock Text="{Binding NhanVienText}" Foreground="#B2DFDB" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Thong tin doanh thu -->
        <Border Grid.Row="1" Background="White" CornerRadius="0" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding TongHoaDonText}" FontSize="14"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DoanhThuTruocGiamText}" FontSize="14"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding TongGiamGiaText}" FontSize="14"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding SoKhachMoiText}" FontSize="14"/>

                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DoanhThuThucNhanText}"
                           FontSize="18" FontWeight="Bold" Foreground="#E65100"/>
            </Grid>
        </Border>

        <!-- Top mon ban chay -->
        <Border Grid.Row="2" Background="White" CornerRadius="0,0,5,5" Padding="10"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TOP MÓN BÁN CHẠY" FontWeight="Bold" FontSize="14" Foreground="#00695C" Margin="0,0,0,10"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding TopMonList}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,4" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding STT}" FontWeight="Bold" Foreground="#00695C"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TenMonAn}" FontSize="14"/>
                                    <TextBlock Grid.Column="2" Text="{Binding SoLuong, StringFormat='x {}{0}'}" Foreground="#757575"/>
                                    <TextBlock Grid.Column="3" Text="{Binding DoanhThu, StringFormat='{}{0:N0} VND'}" FontWeight="Bold" Foreground="#E65100" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="📄 XUẤT BÁO CÁO" Height="35" Width="140"
                    Command="{Binding XuatBaoCaoCommand}"
                    Background="#00695C" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="5,0" FontWeight="Bold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5" Padding="10,5">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="DONG" Height="35" Width="100"
                    Background="#757575" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="5,0"
                    Click="Dong_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5" Padding="10,5">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
