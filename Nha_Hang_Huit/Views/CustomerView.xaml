<Window x:Class="Nha_Hang_Huit.Views.CustomerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Khách Hàng"
        WindowStartupLocation="CenterScreen"
        Width="800" Height="550" WindowStyle="ToolWindow"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ====== LEFT: Danh sach ====== -->
        <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DANH SÁCH KHÁCH HÀNG" FontWeight="Bold" FontSize="14" Foreground="#2E7D32" Margin="0,0,0,5"/>

                <TextBox Grid.Row="1" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Height="30" Margin="0,0,0,10" Padding="5"
                         ToolTip="Tìm kiếm theo tên hoặc SDT"/>

                <ListBox Grid.Row="2" ItemsSource="{Binding KhachHangList}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding TenKhachHang}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SoDienThoai}" FontSize="12" Foreground="#757575"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="3" Padding="5,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding HangThe}" FontSize="11" Foreground="#2E7D32" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="3" Text="{Binding TongKHText}" FontSize="12"
                           Foreground="#757575" Margin="0,5,0,0"/>
            </Grid>
        </Border>

        <!-- ====== RIGHT: Tim kiem + Them ====== -->
        <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TÌM KIẾM / CHỌN" FontWeight="Bold"
                           FontSize="14" Foreground="#1565C0" Margin="0,0,0,10"/>

                <!-- Tim kiem -->
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Số điện thoại:" FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding SoDienThoaiTim}" Height="30" Padding="5"/>
                </StackPanel>

                <Button Grid.Row="2" Content="🔍 TÌM" Height="35"
                        Command="{Binding TimCommand}"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,0,10"/>

                <!-- Thong tin khach hang -->
                <Border Grid.Row="3" Background="#E3F2FD" CornerRadius="5" Padding="8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TenKH}" FontSize="16" FontWeight="Bold" Foreground="#1565C0"/>
                        <TextBlock Text="{Binding SDTKH}" FontSize="13" Foreground="#424242"/>
                        <WrapPanel Margin="0,5,0,0">
                            <TextBlock Text="{Binding HangTheKH}" FontWeight="Bold" Foreground="#2E7D32"/>
                            <TextBlock Text=" | " Foreground="#BDBDBD"/>
                            <TextBlock Text="{Binding DiemKH}" Foreground="#E65100"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4" Margin="0,0,0,10">
                    <TextBlock Text="THÊM KHÁCH HÀNG MỚI" FontWeight="Bold"
                               FontSize="12" Foreground="#2E7D32" Margin="0,10,0,5"/>
                    <TextBox Text="{Binding TenKHMoi}" Height="30" Padding="5" Margin="0,0,0,5"
                             ToolTip="Tên khách hàng"/>
                    <TextBox Text="{Binding SdtKHMoi}" Height="30" Padding="5" Margin="0,0,0,5"
                             ToolTip="Số điện thoại"/>
                    <Button Content="➕ THÊM" Height="30"
                            Command="{Binding ThemCommand}"
                            Background="#2E7D32" Foreground="White"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,3">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Bottom buttons -->
                <StackPanel Grid.Row="5">
                    <Button Content="✅ CHỌN KHÁCH HÀNG NÀY" Height="35"
                            Command="{Binding ChonKHCommand}"
                            Background="#E65100" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,0,5"
                            FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="ĐÓNG" Height="30"
                            Command="{x:Null}"
                            Background="#757575" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="Dong_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,3">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
