<Window x:Class="Nha_Hang_Huit.Views.StaffManagementView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý nhân viên - Nhà Hàng HUIT"
        WindowStartupLocation="CenterScreen"
        Width="700" Height="500" WindowStyle="ToolWindow"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E3F2FD" Offset="0"/>
            <GradientStop Color="#F5F5F5" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1565C0" CornerRadius="6" Padding="14,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#x1F465;" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="QUAN LY NHAN VIEN" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding TongNhanVienText}" Foreground="#90CAF9" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding DangLamText}" Foreground="#A5D6A7" FontSize="13" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Staff list -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="2">
            <DataGrid ItemsSource="{Binding StaffList}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" RowHeaderWidth="0"
                      BorderThickness="0" FontSize="13"
                      AlternatingRowBackground="#F5F5F5"
                      SelectionMode="Single">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TrangThai}" Value="False">
                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ma NV" Binding="{Binding MaNhanVien}" Width="70"/>
                    <DataGridTextColumn Header="Ho ten" Binding="{Binding HoTen}" Width="*"/>
                    <DataGridTextColumn Header="Tai khoan" Binding="{Binding TaiKhoan}" Width="120"/>
                    <DataGridTextColumn Header="Chuc vu" Binding="{Binding ChucVu}" Width="120"/>
                    <DataGridTextColumn Header="Trang thai" Binding="{Binding TrangThaiText}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="3" Content="DONG" Height="36" Width="120" Margin="0,8,0,0"
                Command="{Binding DongCommand}"
                Background="#757575" Foreground="White"
                BorderThickness="0" Cursor="Hand" FontSize="13" FontWeight="Bold"
                HorizontalAlignment="Right">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="12,5">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
