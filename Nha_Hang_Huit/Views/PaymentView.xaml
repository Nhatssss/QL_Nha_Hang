<Window x:Class="Nha_Hang_Huit.Views.PaymentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh Toan"
        WindowStartupLocation="CenterScreen"
        Width="850" Height="600" WindowStyle="ToolWindow"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Table info banner -->
        <Border Grid.Row="0" Background="#1B5E20" CornerRadius="4" Padding="10,5" Margin="0,0,0,10"
                DataContext="{Binding BanHienTai}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding TenBan, StringFormat='    Ban {0}'}"
                           Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text=" | " Foreground="#A5D6A7" FontSize="16" Margin="5,0"/>
                <TextBlock Text="{Binding TenKhuVuc}" Foreground="#C8E6C9" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- ====== LEFT: Chi tiet hoa don ====== -->
            <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="CHI TIET HOA DON" FontWeight="Bold" FontSize="14" Foreground="#2E7D32" Margin="0,0,0,10"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding ChiTietItems}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="5" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TenMonAn}" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SoLuong, StringFormat='x {}{0}'}" Foreground="#757575"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ThanhTien, StringFormat='{}{0:N0} VND'}" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Summary -->
                <Border Grid.Row="2" Background="#E8F5E9" CornerRadius="5" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tong tien:" FontSize="14"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TongTienText}" FontSize="14" Foreground="#E65100" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Giam gia:" FontSize="14"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GiamGiaText}" FontSize="14" Foreground="#C62828"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Thanh toan:" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ThanhToanText}" FontSize="18" FontWeight="Bold" Foreground="#E65100"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ====== RIGHT: Thanh toan ====== -->
        <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="THANH TOAN" FontWeight="Bold" FontSize="14" Foreground="#E65100" Margin="0,0,0,10"/>

                <!-- ===== SO DIEN THOAI + GIAM GIA THEO HANG ===== -->
                <GroupBox Grid.Row="1" Header="Giam gia theo hang (nhap SDT)" Margin="0,0,0,10" Padding="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- So dien thoai -->
                        <TextBox Grid.Row="0" Text="{Binding SoDienThoaiInput, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" FontSize="14" Padding="3"
                                 x:Name="txtSoDienThoai"
                                 TextChanged="txtSoDienThoai_TextChanged"/>

                        <!-- Autocomplete suggestions -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding DanhSachGoiY}"
                                 Visibility="{Binding CoGoiY, Converter={StaticResource BoolToVis}}"
                                 MaxHeight="120" Margin="0,2,0,5"
                                 x:Name="lbGoiY"
                                 PreviewMouseDown="lbGoiY_PreviewMouseDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Cursor="Hand">
                                        <StackPanel>
                                            <TextBlock Text="{Binding HienThi}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="11" Foreground="#757575">
                                                <Run Text="{Binding HangThe, StringFormat='Hang: {0}'}"/>
                                                <Run Text=" | "/>
                                                <Run Text="Diem: "/>
                                                <Run Text="{Binding TongDiemTichLuy}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CoGoiY}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CoGoiY}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                        </ListBox>

                        <!-- Thong tin khach hang da chon -->
                        <Border Grid.Row="2" Background="#E8F5E9" CornerRadius="4" Padding="5"
                                Margin="0,5,0,0"
                                BorderBrush="#A5D6A7" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding TenKhachHangInfo}" FontSize="14" FontWeight="Bold" Foreground="#2E7D32"/>
                                <TextBlock Text="{Binding HangTheInfo}" FontSize="12" Foreground="#558B2F"/>
                                <TextBlock Text="{Binding TiLeGiamGiaText}" FontSize="13" FontWeight="Bold" Foreground="#E65100"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </GroupBox>

                <!-- Phuong thuc thanh toan -->
                <GroupBox Grid.Row="2" Header="Phương thức" Margin="0,0,0,10">
                    <StackPanel>
                        <RadioButton Content="Tiền mặt" IsChecked="True"
                                     GroupName="PhuongThuc" Margin="5,5"/>
                        <RadioButton Content="QR Code" Margin="5,5"
                                     GroupName="PhuongThuc"/>
                    </StackPanel>
                </GroupBox>

                <!-- Tien khach dua -->
                <StackPanel Grid.Row="3" Margin="0,0,0,10">
                    <TextBlock Text="Tiền khách đưa:" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding TienKhachDua, UpdateSourceTrigger=PropertyChanged}"
                             Height="35" FontSize="18" Padding="5" TextAlignment="Right"/>
                </StackPanel>

                <!-- Tien thua / Thong bao -->
                <Border Grid.Row="4" Background="#FFF3E0" CornerRadius="5" Padding="8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TienThuaText}" FontSize="16"
                                   FontWeight="Bold" Foreground="#E65100"/>
                        <TextBlock Text="{Binding ThongBaoTT}"
                                   Foreground="Red" FontSize="13"
                                   Visibility="{Binding CoThongBaoTT, Converter={StaticResource BoolToVis}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CoThongBaoTT}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CoThongBaoTT}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- QR Code area -->
                <Border Grid.Row="5" Background="#F5F5F5" CornerRadius="5" Padding="8" Margin="0,0,0,10"
                        Visibility="{Binding QRVisible}">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{Binding QRImage}" Width="180" Height="180" Stretch="Uniform"/>
                        <TextBlock Text="{Binding QRInfo}" FontSize="12" Foreground="#757575"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="6" Background="#E8F5E9" CornerRadius="5" Padding="5"
                        Visibility="{Binding QRResultVisible}">
                    <TextBlock Text="{Binding QRResultText}" FontSize="13" FontWeight="Bold"
                               Foreground="#2E7D32" HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="7" Text="" Visibility="Collapsed"/>

                <!-- Buttons -->
                <StackPanel Grid.Row="8">
                    <Button Content="✅ XÁC NHẬN THANH TOÁN" Height="40"
                            Command="{Binding XacNhanTTCommand}"
                            Background="#2E7D32" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontWeight="Bold" Margin="0,0,0,5">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📱 TẠO QR" Height="35"
                            Command="{Binding TaoQRCommand}"
                            Background="#1565C0" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,0,5">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="DONG" Height="30"
                            Background="#757575" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="Dong_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="10,3">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Grid>
</Window>
