<Window x:Class="Nha_Hang_Huit.Views.ManagerReportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Báo cáo tổng hợp - Nhà Hàng HUIT"
        WindowStartupLocation="CenterScreen"
        Width="900" Height="650" WindowStyle="ToolWindow"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E0F2F1" Offset="0"/>
            <GradientStop Color="#F1F8E9" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#00695C" CornerRadius="6" Padding="14,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#x1F4CA;" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="BÁO CÁO TỔNG HỢP" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding TongCaText}" Foreground="#B2DFDB" FontSize="13" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Thong bao neu khong co du lieu -->
        <Border Grid.Row="1" Background="#FFF9C4" CornerRadius="5" Padding="10"
                Visibility="{Binding CoDuLieu, Converter={StaticResource InvertBoolToVis}}" Margin="0,0,0,8">
            <TextBlock Text="Chua co ca nao duoc dong! Du lieu chi hien thi sau khi co ca ket thuc."
                       FontSize="13" Foreground="#F57F17" HorizontalAlignment="Center"/>
        </Border>

        <!-- Thong tin tong hop -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8"
                Visibility="{Binding CoDuLieu, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="HOA DON" FontSize="11" Foreground="#757575" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TongHoaDonText}" FontSize="18" FontWeight="Bold" Foreground="#00695C" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="DOANH THU" FontSize="11" Foreground="#757575" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DoanhThuTruocGiamText}" FontSize="18" FontWeight="Bold" Foreground="#E65100" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="GIAM GIA" FontSize="11" Foreground="#757575" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TongGiamGiaText}" FontSize="18" FontWeight="Bold" Foreground="#C62828" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="THUC NHAN" FontSize="11" Foreground="#757575" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DoanhThuThucNhanText}" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: Tab control -->
        <TabControl Grid.Row="2" Margin="0,0,0,8"
                    Visibility="{Binding CoDuLieu, Converter={StaticResource BoolToVis}}">
            <!-- Tab 1: Danh sach ca -->
            <TabItem Header="DANH SÁCH CA ĐÃ ĐÓNG">
                <Border Background="White" CornerRadius="0,0,6,6" Padding="2">
                    <DataGrid ItemsSource="{Binding CaList}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" RowHeaderWidth="0"
                              BorderThickness="0" FontSize="13"
                              AlternatingRowBackground="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ma Ca" Binding="{Binding MaCa}" Width="70"/>
                            <DataGridTextColumn Header="Ngay" Binding="{Binding Ngay}" Width="120"/>
                            <DataGridTextColumn Header="Nhan Vien" Binding="{Binding NhanVien}" Width="*"/>
                            <DataGridTextColumn Header="So HD" Binding="{Binding TongHoaDon}" Width="80"/>
                            <DataGridTextColumn Header="Doanh Thu" Binding="{Binding DoanhThuDisplay}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Tab 2: Top mon ban chay -->
            <TabItem Header="TOP 10 MÓN BÁN CHẠY">
                <Border Background="White" CornerRadius="0,0,6,6" Padding="2">
                    <DataGrid ItemsSource="{Binding TopMonList}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" RowHeaderWidth="0"
                              BorderThickness="0" FontSize="13"
                              AlternatingRowBackground="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50"/>
                            <DataGridTextColumn Header="Ten Mon" Binding="{Binding TenMonAn}" Width="*"/>
                            <DataGridTextColumn Header="So Luong" Binding="{Binding SoLuong}" Width="100"/>
                            <DataGridTextColumn Header="Doanh Thu" Binding="{Binding DoanhThuDisplay}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Close button -->
        <Button Grid.Row="3" Content="DONG" Height="36" Width="120"
                Command="{Binding DongCommand}"
                Background="#757575" Foreground="White"
                BorderThickness="0" Cursor="Hand" FontSize="13" FontWeight="Bold"
                HorizontalAlignment="Right">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="12,5">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
