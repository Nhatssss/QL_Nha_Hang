<Window x:Class="Nha_Hang_Huit.Views.TopMonView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Top Món Bán Chạy"
        Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E0F2F1" Offset="0"/>
            <GradientStop Color="#F1F8E9" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid Margin="15">
        <Grid.Resources>
            <Style x:Key="CellLeftStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="5,0"/>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="THỐNG KÊ TOP MÓN BÁN CHẠY" FontSize="18" FontWeight="Bold"
                       Foreground="#004D40"/>
            <TextBlock Text="{Binding MaCaText}" FontSize="13" Foreground="#757575"/>
        </StackPanel>

        <!-- Data Grid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding TopMonList}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5"
                  Background="White" BorderBrush="#BDBDBD" BorderThickness="1"
                  FontSize="13" RowHeight="35"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50"/>
                <DataGridTextColumn Header="Tên Món Ăn" Binding="{Binding TenMonAn}" Width="*"
                                    ElementStyle="{StaticResource CellLeftStyle}"/>
                <DataGridTextColumn Header="Số Lượng" Binding="{Binding SoLuong}" Width="100"/>
                <DataGridTextColumn Header="Doanh Thu" Binding="{Binding DoanhThuText}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Background="White" Padding="10" Margin="0,10,0,0"
                CornerRadius="0,0,5,5" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding TongText}"
                           FontWeight="Bold" FontSize="14" Foreground="#004D40"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="💾 Xuất báo cáo" Height="32" Margin="0,0,10,0"
                            Command="{Binding XuatBaoCaoCommand}"
                            Background="#004D40" Foreground="White" BorderThickness="0"
                            Padding="12,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="12,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="❌ Đóng" Height="32"
                            Command="{Binding DongCommand}"
                            Background="#757575" Foreground="White" BorderThickness="0"
                            Padding="12,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="12,5">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
