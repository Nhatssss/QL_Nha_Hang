<Window x:Class="Nha_Hang_Huit.Views.OrderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gọi Món"
        WindowStartupLocation="CenterScreen"
        Width="900" Height="600" WindowStyle="ToolWindow"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Table info banner (shown only when a table is selected) -->
        <Border Grid.Row="0" Background="#1B5E20" CornerRadius="4" Padding="10,5" Margin="0,0,0,10"
                DataContext="{Binding BanHienTai}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding TenBan, StringFormat='    Ban {0}'}"
                           Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text=" | " Foreground="#A5D6A7" FontSize="16" Margin="5,0"/>
                <TextBlock Text="{Binding TenKhuVuc}" Foreground="#C8E6C9" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ====== LEFT: Nhom mon ====== -->
            <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="5" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="NHÓM MÓN" FontWeight="Bold"
                               Foreground="#2E7D32" FontSize="14" Margin="5,0,0,10"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding NhomMonList}"
                             SelectedItem="{Binding NhomMonSelected}"
                             FontSize="14"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Padding="8,6"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ====== CENTER: Danh sach mon ====== -->
            <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="5" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="MENU" FontWeight="Bold"
                               Foreground="#2E7D32" FontSize="14" Margin="5,0,0,10"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding MonAnList}"
                             SelectedItem="{Binding MonDaChon}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding TenMonAn}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Gia, StringFormat='{}{0:N0} VND'}"
                                                   Foreground="#E65100" FontSize="13"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ====== RIGHT: Gio hang tam + Them ====== -->
            <Border Grid.Column="2" Background="White" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Mon da chon -->
                    <Border Grid.Row="0" Background="#E8F5E9" CornerRadius="5" Padding="8" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="MÓN ĐÃ CHỌN" FontWeight="Bold" Foreground="#2E7D32" FontSize="12"/>
                            <TextBlock Text="{Binding MonDaChonDisplay}" FontSize="16" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding GiaDaChonDisplay}" Foreground="#E65100" FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <!-- So luong -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="−" Width="35" Height="35" FontSize="18"
                                    Command="{Binding GiamSLCommand}"
                                    Background="#E0E0E0" BorderThickness="0" Cursor="Hand"/>
                            <TextBlock Text="{Binding SoLuong}" Width="50" Height="35"
                                       TextAlignment="Center" VerticalAlignment="Center"
                                       FontSize="20" FontWeight="Bold"/>
                            <Button Content="+" Width="35" Height="35" FontSize="18"
                                    Command="{Binding TangSLCommand}"
                                    Background="#E0E0E0" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <!-- Gio hang tam -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding GioHangItems}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding TenMonAn}" FontSize="13"/>
                                            <TextBlock Text="{Binding SoLuong, StringFormat='SL: {}{0}'}" FontSize="11" Foreground="#757575"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding ThanhTien, StringFormat='{}{0:N0}'}"
                                                   FontWeight="Bold" Foreground="#2E7D32" FontSize="13" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Bottom buttons -->
                    <StackPanel Grid.Row="3">
                        <TextBlock Text="{Binding TongGioHangText}" FontSize="16"
                                   FontWeight="Bold" Foreground="#E65100"
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>

                        <Button Content="➕ THÊM VÀO GIỎ" Height="35"
                                Command="{Binding ThemVaoGioCommand}"
                                Background="#2E7D32" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                FontWeight="Bold" Margin="0,0,0,5">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="ĐÓNG" Height="30"
                                Command="{Binding DongCommand}"
                                Background="#757575" Foreground="White"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,3">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
