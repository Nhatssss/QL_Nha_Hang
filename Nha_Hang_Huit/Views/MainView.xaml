<Window x:Class="Nha_Hang_Huit.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nha Hang HUIT - Phan mem quan ly"
        WindowState="Maximized" WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F5E9" Offset="0"/>
            <GradientStop Color="#F1F8E9" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ====== TOOLBAR ====== -->
        <Border Grid.Row="0" Background="#2E7D32" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <TextBlock Grid.Column="0" Text="NHÀ HÀNG HUIT"
                           FontSize="22" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,30,0"/>

                <!-- Ca status / Admin badge -->
                <Border Grid.Column="1" Background="#1B5E20" CornerRadius="4" Padding="10,5" Margin="0,0,20,0">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding TrangThaiCaText}"
                                   Foreground="#FFF9C4" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="{Binding TenNhanVienText}"
                                   Foreground="#C8E6C9" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Quick stats -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TongHoaDonText}" Foreground="White" FontSize="13" Margin="10,0"/>
                    <TextBlock Text=" | " Foreground="#A5D6A7" FontSize="13"/>
                    <TextBlock Text="Doanh thu: " Foreground="White" FontSize="13"/>
                    <TextBlock Text="{Binding DoanhThuText}" Foreground="#FFF9C4" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <!-- Refresh button -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="🔄 Cập nhật" Height="32"
                            Command="{Binding RefreshCommand}"
                            Background="#43A047" Foreground="White" Margin="3,0"
                            BorderThickness="0" Padding="10,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="10,4">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Logout button -->
                    <Button Content="🚪 Đăng xuất" Height="32"
                            Command="{Binding DangXuatCommand}"
                            Background="#C62828" Foreground="White" Margin="6,0,0,0"
                            BorderThickness="0" Padding="10,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="10,4">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ====== MAIN CONTENT ====== -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

                        <!-- ======================== UNIFIED SIDEBAR ======================== -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,0"
                    Visibility="Visible">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <!-- Header -->
                        <TextBlock Text="MENU" FontSize="14" FontWeight="Bold"
                                   Foreground="#00695C" Margin="0,5,0,12"
                                   Visibility="{Binding AdminSectionVisibility}"/>

                        <!-- =========== SECTION: CA =========== -->
                        <Button Content="M? CA" Height="40" Margin="0,0,0,5"
                                Command="{Binding MoCaCommand}"
                                Background="#2E7D32" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                Visibility="{Binding MoCaVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="D?NG CA" Height="40" Margin="0,0,0,5"
                                Command="{Binding DongCaCommand}"
                                Background="#C62828" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                Visibility="{Binding DongCaVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Margin="0,5" Visibility="{Binding ChucNangSectionVisibility}"/>

                        <!-- =========== SECTION: CHUC NANG (khi da mo ca) =========== -->
                        <TextBlock Text="CH?C N?NG" FontSize="12" FontWeight="Bold"
                                   Foreground="#2E7D32" Margin="0,0,0,8"
                                   Visibility="{Binding ChucNangSectionVisibility}"/>

                        <Button Content="G?I M?N &amp; THANH TO?N" Height="40" Margin="0,0,0,5"
                                Command="{Binding MoMenuCommand}"
                                Background="#1565C0" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                IsEnabled="{Binding CoTheThaoTac}"
                                Visibility="{Binding ChucNangSectionVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="KH?CH H?NG" Height="40" Margin="0,0,0,5"
                                Command="{Binding MoKhachHangCommand}"
                                Background="#6A1B9A" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                IsEnabled="{Binding CoTheThaoTac}"
                                Visibility="{Binding ChucNangSectionVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="X?A GI? H?NG" Height="35" Margin="0,0,0,5"
                                Command="{Binding XoaGioHangCommand}"
                                Background="#757575" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                IsEnabled="{Binding CoTheThaoTac}"
                                Visibility="{Binding ChucNangSectionVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Margin="0,5" Visibility="{Binding AdminSectionVisibility}"/>

                        <!-- =========== SECTION: QUAN LY (admin only) =========== -->
                        <TextBlock Text="QU?N L?" FontSize="12" FontWeight="Bold"
                                   Foreground="#00695C" Margin="0,0,0,8"
                                   Visibility="{Binding AdminSectionVisibility}"/>

                        <Button Content="B?O C?O DOANH THU" Height="40" Margin="0,0,0,5"
                                Command="{Binding MoBaoCaoAllCommand}"
                                Background="#00695C" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                Visibility="{Binding AdminSectionVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="TOP M?N B?N CH?Y" Height="40" Margin="0,0,0,5"
                                Command="{Binding MoTopMonAllCommand}"
                                Background="#004D40" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                Visibility="{Binding AdminSectionVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="NH?N VIEN" Height="40" Margin="0,0,0,5"
                                Command="{Binding MoStaffManagementCommand}"
                                Background="#1565C0" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                Visibility="{Binding AdminSectionVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="L?CH S? H?A D?N" Height="40" Margin="0,0,0,5"
                                Command="{Binding MoInvoiceHistoryCommand}"
                                Background="#6A1B9A" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Padding="10,0"
                                Visibility="{Binding AdminSectionVisibility}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Margin="0,10"/>

                        <!-- =========== SECTION: THONG TIN NHANH =========== -->
                        <TextBlock Text="TH?NG TIN NHANH" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>

                        <Border Background="#E0F2F1" CornerRadius="5" Padding="8" Margin="0,0,0,5">
                            <StackPanel>
                                <TextBlock Text="{Binding TongHoaDonText}" FontSize="13"/>
                                <TextBlock Text="{Binding DoanhThuText}" FontSize="16" FontWeight="Bold" Foreground="#E65100"/>
                                <TextBlock Text="H?m nay" FontSize="11" Foreground="#757575" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
<!-- ====== RIGHT CONTENT ====== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Thong bao -->
                <Border Grid.Row="0" Background="#FFF9C4" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <TextBlock Text="{Binding ThongBaoHienTai}" FontSize="13" Foreground="#F57F17"/>
                </Border>

                <!-- ====== ADMIN DASHBOARD ====== -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20"
                        Visibility="{Binding AdminPanelVisibility}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="BẢNG ĐIỀU KHIỂN QUẢN LÝ" FontSize="22" FontWeight="Bold"
                                   Foreground="#00695C" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                        <Border Background="#E0F2F1" CornerRadius="10" Padding="30" Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="10">
                                    <TextBlock Text="TỔNG HÓA ĐƠN" FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TongHoaDonText}" FontSize="24" FontWeight="Bold"
                                               Foreground="#00695C" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="10">
                                    <TextBlock Text="DOANH THU" FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DoanhThuText}" FontSize="24" FontWeight="Bold"
                                               Foreground="#E65100" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Chọn chức năng bên trái để xem báo cáo chi tiết."
                                   FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ====== NHAN VIEN: TABLE LAYOUT ====== -->
                <Grid Grid.Row="1" Visibility="{Binding NhanVienVisibility}">
                    <!-- Blocking overlay: chua mo ca -->
                    <Border Background="#80FFFFFF"
                            Visibility="{Binding NoCaBlockedVisibility}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⛔" FontSize="64" HorizontalAlignment="Center"/>
                            <TextBlock Text="CHƯA MỞ CA" FontSize="24" FontWeight="Bold"
                                       Foreground="#C62828" HorizontalAlignment="Center" Margin="0,10,0,5"/>
                            <TextBlock Text="Vui lòng nhấn nút MỞ CA bên trái để bắt đầu làm việc!"
                                       FontSize="14" Foreground="#757575" HorizontalAlignment="Center"/>
                            <TextBlock Text="Các chức năng sẽ được kích hoạt sau khi mở ca."
                                       FontSize="13" Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ====== TABLE FLOOR PLAN (khi da mo ca) ====== -->
                    <Grid Visibility="{Binding CaDaMoVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Thong bao -->
                        <Border Grid.Row="0" Background="#FFF9C4" CornerRadius="5" Padding="8" Margin="0,0,0,5">
                            <TextBlock Text="{Binding ThongBaoHienTai}" FontSize="13" Foreground="#F57F17"/>
                        </Border>

                        <!-- Row 1: Khu vuc tabs + Table status summary -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Khu vuc tabs -->
                            <ListBox Grid.Column="0" ItemsSource="{Binding KhuVucList}"
                                     SelectedItem="{Binding KhuVucSelected}"
                                     SelectionMode="Single"
                                     BorderThickness="0" Background="Transparent">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E8F5E9" CornerRadius="4" Padding="12,6" Margin="0,0,5,0" Cursor="Hand">
                                            <TextBlock Text="{Binding TenKhuVuc}" FontSize="13" FontWeight="SemiBold" Foreground="#2E7D32"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Table status summary -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Ellipse Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SoBanTrong, StringFormat=' {0}'}" FontSize="12" Foreground="#757575" Margin="2,0,0,0"/>
                                    <TextBlock Text="trong" FontSize="12" Foreground="#757575" Margin="0,0,5,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Ellipse Width="10" Height="10" Fill="#FF9800" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SoBanDangDung, StringFormat=' {0}'}" FontSize="12" Foreground="#757575" Margin="2,0,0,0"/>
                                    <TextBlock Text="dung" FontSize="12" Foreground="#757575" Margin="0,0,5,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Ellipse Width="10" Height="10" Fill="#9E9E9E" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SoBanDaDat, StringFormat=' {0}'}" FontSize="12" Foreground="#757575" Margin="2,0,0,0"/>
                                    <TextBlock Text="dat" FontSize="12" Foreground="#757575"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: Table grid -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding BanAnList}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="130" Height="95" Margin="6" CornerRadius="8"
                                                BorderThickness="2" Cursor="Hand"
                                                Background="White"
                                                ToolTip="{Binding TrangThaiDisplay}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TrangThai}" Value="Trong">
                                                            <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TrangThai}" Value="DangDung">
                                                            <Setter Property="BorderBrush" Value="#FF9800"/>
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TrangThai}" Value="DaDat">
                                                            <Setter Property="BorderBrush" Value="#9E9E9E"/>
                                                            <Setter Property="Background" Value="#F5F5F5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- Table info -->
                                                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding TenBan}" FontSize="18" FontWeight="Bold"
                                                               HorizontalAlignment="Center" Foreground="#333"/>
                                                    <TextBlock Text="{Binding SoChoNgoi, StringFormat='{}{0} nguoi'}" FontSize="11"
                                                               HorizontalAlignment="Center" Foreground="#888"/>
                                                </StackPanel>
                                                <!-- Amount if occupied -->
                                                <TextBlock Grid.Row="1" Text="{Binding TongTienDisplay}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="#E65100"
                                                           HorizontalAlignment="Center" Margin="2,0,2,3"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding DataContext.ChonBanCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Row 3: Bottom bar - Selected table info + quick actions -->
                        <Border Grid.Row="3" Background="#E8F5E9" CornerRadius="5" Padding="8" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Table info -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                                    <TextBlock Text="{Binding BanHienTaiText}" FontSize="13" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Cart total -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TongTienGioHangText}" FontSize="16" FontWeight="Bold" Foreground="#E65100" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Action button: combined order + payment -->
                                <Button Grid.Column="3" Content="&#x1F4CB; GỌI MÓN &amp; THANH TOÁN" Height="34" Padding="14,0" Margin="3,0"
                                        Command="{Binding GoiMonChoBanCommand}"
                                        Background="#E65100" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        FontSize="12" FontWeight="Bold">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                                            <ContentPresenter HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>




