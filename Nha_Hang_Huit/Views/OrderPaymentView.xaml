<Window x:Class="Nha_Hang_Huit.Views.OrderPaymentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Goi mon &amp; Thanh toan"
        WindowStartupLocation="CenterScreen"
        Width="1100" Height="700" WindowStyle="ToolWindow"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F5E9" Offset="0"/>
            <GradientStop Color="#F1F8E9" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER: Table info ===== -->
        <Border Grid.Row="0" Background="#1B5E20" CornerRadius="6" Padding="12,6" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#x1F4CB;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding BanTitle}" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding TongTienDisplay}" FontSize="18" FontWeight="Bold" Foreground="#FFF9C4" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- ===== COLUMN 0: NHOM MON ===== -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="6" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="NHÓM MÓN" FontWeight="Bold"
                               Foreground="#2E7D32" FontSize="14" Margin="4,4,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding NhomMonList}"
                             SelectedItem="{Binding NhomMonSelected}"
                             FontSize="14" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="2" CornerRadius="4" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding}" FontSize="14"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ===== COLUMN 1: DANH SACH MON ===== -->
            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="6" Margin="3,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="MENU" FontWeight="Bold"
                               Foreground="#2E7D32" FontSize="14" Margin="4,4,0,8"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding MonAnList}"
                             SelectedItem="{Binding MonDaChon}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1" CornerRadius="3">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding TenMonAn}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Gia, StringFormat='{}{0:N0} VND'}"
                                                   Foreground="#E65100" FontSize="13"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Bottom: SL + Them vao gio -->
                    <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="6" Padding="8" Margin="0,6,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- +/- SL -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                                <Button Content="−" Width="32" Height="32" FontSize="16" FontWeight="Bold"
                                        Command="{Binding GiamSLCommand}"
                                        Background="#E0E0E0" BorderThickness="0" Cursor="Hand"/>
                                <TextBlock Text="{Binding SoLuongMon}" Width="40" Height="32"
                                           TextAlignment="Center" VerticalAlignment="Center"
                                           FontSize="18" FontWeight="Bold"/>
                                <Button Content="+" Width="32" Height="32" FontSize="16" FontWeight="Bold"
                                        Command="{Binding TangSLCommand}"
                                        Background="#E0E0E0" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>

                            <!-- Selected item name -->
                            <TextBlock Grid.Column="1" Text="{Binding MonDaChonInfo}"
                                       VerticalAlignment="Center" FontSize="12" Foreground="#757575"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- Them button -->
                            <Button Grid.Column="3" Content="&#x2795; THÊM VÀO GIỎ" Height="34"
                                    Command="{Binding ThemVaoGioCommand}"
                                    Background="#2E7D32" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Padding="12,0"
                                    FontWeight="Bold" FontSize="12"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ===== COLUMN 2: GIO HANG + THANH TOAN ===== -->
            <Border Grid.Column="2" Background="White" CornerRadius="6" Padding="8" Margin="3,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0" Text="GIỎ HÀNG" FontWeight="Bold"
                               Foreground="#2E7D32" FontSize="14" Margin="0,4,0,6"/>

                    <!-- Cart list -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding GioHangItems}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,4" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TenMonAn}" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SoLuong, StringFormat='x {}{0}'}"
                                                   Foreground="#757575" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ThanhTien, StringFormat='{}{0:N0} VND'}"
                                                   FontWeight="Bold" Foreground="#2E7D32" FontSize="13"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="&#x2716;" FontSize="12"
                                                   Foreground="#C62828" Cursor="Hand"
                                                   HorizontalAlignment="Center"
                                                   ToolTip="Xoa">
                                            <TextBlock.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding DataContext.XoaItemGioCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                            </TextBlock.InputBindings>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Separator -->
                    <Border Grid.Row="2" Background="#E0E0E0" Height="1" Margin="0,6"/>

                    <!-- Total section -->
                    <Grid Grid.Row="3" Margin="0,6,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tong tien:" FontSize="13"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TongTienDisplay}" FontSize="13" Foreground="#E65100" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Giam gia:" FontSize="13"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GiamGiaDisplay}" FontSize="13" Foreground="#C62828"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Thanh toan:" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ThanhToanDisplay}" FontSize="18" FontWeight="Bold" Foreground="#E65100"/>
                    </Grid>

                    <Border Grid.Row="4" Background="#E0E0E0" Height="1" Margin="0,4"/>

                    <!-- Customer lookup -->
                    <GroupBox Grid.Row="5" Header="Khach hang (SDT)" Margin="0,8,0,0" Padding="4">
                        <StackPanel>
                            <TextBox Text="{Binding SoDienThoaiInput, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28" FontSize="13" Padding="3"
                                     x:Name="txtSoDienThoai"/>
                            <ListBox ItemsSource="{Binding DanhSachGoiY}"
                                     Visibility="{Binding CoGoiY, Converter={StaticResource BoolToVis}}"
                                     MaxHeight="80" Margin="0,2,0,0" BorderThickness="0"
                                     x:Name="lbGoiY">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="4" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Cursor="Hand">
                                            <StackPanel>
                                                <TextBlock Text="{Binding HienThi}" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock FontSize="10" Foreground="#757575">
                                                    <Run Text="{Binding HangThe, StringFormat='Hang: {0}'}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Background="#E8F5E9" CornerRadius="4" Padding="4" Margin="0,4,0,0"
                                    BorderBrush="#A5D6A7" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding TenKhachHangInfo}" FontSize="13" FontWeight="Bold" Foreground="#2E7D32"/>
                                    <TextBlock Text="{Binding HangTheInfo}" FontSize="11" Foreground="#558B2F"/>
                                    <TextBlock Text="{Binding TiLeGiamGiaDisplay}" FontSize="12" FontWeight="Bold" Foreground="#E65100"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- Payment method -->
                    <GroupBox Grid.Row="6" Header="Phuong thuc thanh toan" Margin="0,6,0,0" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="&#x1F4B5; Tien mat" IsChecked="{Binding ThanhToanTienMat}"
                                         GroupName="PhuongThuc" Margin="8,4" FontSize="13"/>
                            <RadioButton Content="&#x1F4F1; QR Code" IsChecked="{Binding ThanhToanQR}"
                                         GroupName="PhuongThuc" Margin="8,4" FontSize="13"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Cash input -->
                    <StackPanel Grid.Row="7" Margin="0,6,0,0"
                                IsEnabled="{Binding ThanhToanTienMat}">
                        <TextBlock Text="Tien khach dua:" FontWeight="SemiBold" FontSize="12"/>
                        <TextBox Text="{Binding TienKhachDua, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" FontSize="16" Padding="4" TextAlignment="Right"/>
                        <TextBlock Text="{Binding TienThuaDisplay}" FontSize="14" FontWeight="Bold" Foreground="#E65100" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding ThongBaoTT}" Foreground="Red" FontSize="12"
                                   Visibility="{Binding CoThongBaoTT, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- QR display -->
                    <Border Grid.Row="8" Background="#F5F5F5" CornerRadius="5" Padding="6" Margin="0,6,0,0"
                            Visibility="{Binding QRVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{Binding QRImage}" Width="150" Height="150" Stretch="Uniform"/>
                            <TextBlock Text="{Binding QRInfo}" FontSize="11" Foreground="#757575"
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="9" Margin="0,10,0,0">
                        <Button Content="&#x2705; XÁC NHẬN THANH TOÁN" Height="38"
                                Command="{Binding XacNhanTTCommand}"
                                Background="#2E7D32" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                FontWeight="Bold" FontSize="13" Margin="0,0,0,4">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,4">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="&#x1F4F1; TAO QR" Height="32" Margin="0,0,3,0"
                                    Command="{Binding TaoQRCommand}"
                                    Background="#1565C0" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="11">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,3">
                                                        <ContentPresenter HorizontalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="1" Content="&#x1F5D1; XOA GIO" Height="32" Margin="3,0"
                                    Command="{Binding XoaGioHangCommand}"
                                    Background="#757575" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="11">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,3">
                                                        <ContentPresenter HorizontalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="2" Content="DONG" Height="32" Margin="3,0,0,0"
                                    Command="{Binding DongCommand}"
                                    Background="#9E9E9E" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="11">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,3">
                                                        <ContentPresenter HorizontalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <TextBlock Grid.Row="10" Text=""/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
